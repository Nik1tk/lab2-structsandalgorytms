from datetime import datetime
import base64
import json

class HistoryEntry:
    """Одна запись в истории"""
    def __init__(self, url, timestamp, is_bookmark=False):
        self.url = url
        self.timestamp = timestamp
        self.is_bookmark = is_bookmark

class Node:
    """Узел списка"""
    def __init__(self, data):
        self.data = data
        self.prev = None
        self.next = None

class BrowserHistory:
    def __init__(self):
        self.head = None      
        self.tail = None      
        self.current = None   
    
    def add(self, url, is_bookmark=False):
        """Добавить новую страницу"""
        entry = HistoryEntry(url, datetime.now(), is_bookmark)
        new_node = Node(entry)
        
        if self.current is None:
            
            self.head = new_node
            self.tail = new_node
            self.current = new_node
        else:
            
            if self.current.next:
                self._delete_future()
            
            
            new_node.prev = self.current
            self.current.next = new_node
            self.tail = new_node
            self.current = new_node
    
    def _delete_future(self):
        """Удалить страницы после текущей"""
        node = self.current.next
        while node:
            next_node = node.next
            node.prev = None
            node.next = None
            node = next_node
        self.current.next = None
        self.tail = self.current
    
    def back(self):
        """Назад"""
        if self.current and self.current.prev:
            self.current = self.current.prev
            return True
        return False
    
    def forward(self):
        """Вперед"""
        if self.current and self.current.next:
            self.current = self.current.next
            return True
        return False
    
    def clear(self):
        """Очистить историю"""
        self.head = None
        self.tail = None
        self.current = None
    
    def search_by_domain(self, domain):
        """Поиск по домену"""
        result = []
        node = self.head
        while node:
            if domain.lower() in node.data.url.lower():
                result.append(node.data)
            node = node.next
        return result
    
    def get_current(self):
        """Текущая страница"""
        return self.current.data if self.current else None
    
    def get_all(self):
        """Все записи по порядку"""
        entries = []
        node = self.head
        while node:
            entries.append(node.data)
            node = node.next
        return entries
    

    
    def save_to_base64(self, filename):
        """Сохранить историю в файл (Base64, одна строка - одна запись)"""
        entries = self.get_all()
        lines = []
        
        
        for entry in entries:
            data = {
                'url': entry.url,
                'timestamp': entry.timestamp.isoformat(),
                'is_bookmark': entry.is_bookmark
            }
            lines.append(json.dumps(data))
        
        
        text = '\n'.join(lines)
        encoded = base64.b64encode(text.encode()).decode()
        
        
        with open(filename, 'w', encoding='utf-8') as f:
            f.write(encoded)
        
        print(f"История сохранена в {filename}")
    
    def load_from_base64(self, filename):
        """Загрузить историю из Base64 файла"""
        try:
            
            with open(filename, 'r', encoding='utf-8') as f:
                encoded = f.read()
            
            
            decoded = base64.b64decode(encoded).decode()
            lines = decoded.split('\n')
            
            
            self.clear()
            
            
            for line in lines:
                if line.strip():
                    data = json.loads(line)
                    self.add(data['url'], data['is_bookmark'])
                    
                    if self.tail:
                        self.tail.data.timestamp = datetime.fromisoformat(data['timestamp'])
            
            print(f"История загружена из {filename}")
            return True
        except Exception as e:
            print(f"Ошибка загрузки: {e}")
            return False
    
    def print_table(self):
        """Вывести историю таблицей"""
        if not self.head:
            print("История пуста")
            return
        
        print("\n" + "=" * 70)
        print(f"{'Дата и время':<20} {'Закл':<5} URL")
        print("=" * 70)
        
        node = self.head
        while node:
            entry = node.data
            bookmark = "★" if entry.is_bookmark else " "
            time_str = entry.timestamp.strftime('%Y-%m-%d %H:%M:%S')
            print(f"{time_str:<20} {bookmark:<5} {entry.url}")
            node = node.next
        
        print("=" * 70 + "\n")



def main():
    history = BrowserHistory()
    
    print("=" * 60)
    print("БРАУЗЕРНАЯ ИСТОРИЯ")
    print("=" * 60)
    

    print("\n1. Добавляем страницы:")
    history.add("https://google.com", is_bookmark=True)
    history.add("https://github.com")
    history.add("https://stackoverflow.com")
    history.add("https://youtube.com")
    print("Добавлено 4 страницы")
    

    print("\n2. Текущая история:")
    history.print_table()
    

    print("3. Навигация:")
    print(f"Сейчас: {history.get_current().url}")
    history.back()
    print(f"Нажали 'Назад': {history.get_current().url}")
    history.forward()
    print(f"Нажали 'Вперед': {history.get_current().url}")
    

    print("\n4. Поиск по домену 'google':")
    found = history.search_by_domain("google")
    for entry in found:
        print(f"   - {entry.url}")
    

    print("\n5. Сохраняем историю в файл (Base64):")
    history.save_to_base64("history.txt")
    
    print("\n6. Создаем новую историю и загружаем из файла:")
    new_history = BrowserHistory()
    new_history.load_from_base64("history.txt")
    new_history.print_table()
    

    print("\n7. Очищаем историю:")
    history.clear()
    print(f"После очистки записей: {len(history.get_all())}")

if __name__ == "__main__":
    main()
